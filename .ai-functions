# ================================
# Functions to make working with AI easier on the command line
# ================================

# Usage: ai-find-and-copy <search string>|<files...>
#
# Description:
#   Copies matching file contents to the clipboard.
#   When given file arguments, it concatenates those files with --- separators.
#   When given a search string, it finds files containing that literal text with rg and copies their contents.
#   Shell-expanded globs like tmp/db-lint/* work when they resolve to regular files before the function runs.
ai-find-and-copy() {
  local -a files_to_copy
  local search_string

  if (( $# == 0 )); then
    echo "Usage: ai-find-and-copy <search string>|<files...>"
    return 1
  fi

  # If every argument resolves to an existing file, treat the input as a file list.
  # This makes shell-expanded globs like tmp/db-lint/* behave as expected.
  if [[ -f "$1" ]]; then
    local file
    for file in "$@"; do
      if [[ ! -f "$file" ]]; then
        echo "Expected files, but '$file' does not exist or is not a regular file."
        return 1
      fi
    done

    files_to_copy=("$@")
  else
    search_string="$*"
    files_to_copy=(${(f)$(rg --files-with-matches --no-messages --fixed-strings "$search_string")})

    if (( ${#files_to_copy[@]} == 0 )); then
      echo "No files found with string: $search_string"
      return 1
    fi
  fi

  # Combine contents of the files, separated by "---"
  local file
  for file in "${files_to_copy[@]}"; do
    cat "$file"
    printf '\n---\n\n'
  done | pbcopy  # Copy the combined content to the clipboard
}

# Usage: ai-cat <files...>
#
# Description:
#   Prints each file with a markdown header and fenced code block for quick LLM prompts.
#   Accepts literal file paths and shell-expanded globs like tmp/db-lint/* when the glob matches files.
ai-cat-glob() {
  for file in "$@"; do
    if [[ -f "$file" ]]; then
      echo "### File: $file"
      echo '```'
      /bin/cat "$file"
      echo '```'
      echo ''
    else
      echo "File $file does not exist." >&2
    fi
  done
}

# Description: copy glob match into clipboard (with names)
# Usage: ai-cat-glob <files...>
ai-pbcopy-glob() {
  ai-cat-glob "$@" | pbcopy
}

ask_llm_claude() {
  if (( $# == 0 )); then
    echo "Usage: ask_llm_claude [claude args...]" >&2
    return 1
  fi

  claude -p "$@"
}

ask_llm_gemini() {
  if (( $# == 0 )); then
    echo "Usage: ask_llm_gemini [gemini args...]" >&2
    return 1
  fi

  # gemini dumps a bunch of junk into stderr by default
  gemini -p "$@" 2>/dev/null
}
# can't use a `?` in a function name, only an alias
alias "ai?"="ask_llm_gemini"

# Usage: mcp-inspect <server_key> [path/to/settings.json]
#
# Description:
#   Launches the MCP inspector for a server defined in a JSON5 settings file.
#   It defaults to .gemini/settings.json, expands environment variables in the server config,
#   and passes the configured command and args through to @modelcontextprotocol/inspector.
#   When no server key is provided, it prints usage and lists the available configured servers.
mcp-inspect() {
  local SERVER=$1
  # Defaults to your settings file if a second argument isn't provided
  local CONFIG=${2:-.gemini/settings.json}

  # Ensure the config file exists first
  if [[ ! -f "$CONFIG" ]]; then
    echo "Error: File not found -> $CONFIG"
    return 1
  fi

  # If no server is provided, print usage and list available servers
  if [[ -z "$SERVER" ]]; then
    echo "Usage: mcp-inspect <server_key> [path/to/settings.json]"
    echo "\nAvailable servers in $CONFIG:"
    pnpx json5 "$CONFIG" | jq -r '.mcpServers | keys[] | "  - \(.)"'
    return 1
  fi

  # 1. Parse JSON5 with pnpx, substitute env vars, extract array with jq, escape for shell
  local CMD
  CMD=$(pnpx json5 "$CONFIG" | envsubst | jq -r ".mcpServers[\"$SERVER\"] | select(. != null) | [.command] + (.args // []) | @sh")

  if [[ -z "$CMD" ]]; then
    echo "Error: Server '$SERVER' not found in $CONFIG (or has no command)"
    return 1
  fi

  # Build the final execution string using pnpx
  local EXEC_CMD="pnpx @modelcontextprotocol/inspector $CMD"

  # Print the command in bold cyan (\e[1;36m) and reset (\e[0m)
  printf "\n\e[1;36m🚀 Executing: %s\e[0m\n\n" "$EXEC_CMD"
  
  # 2. Execute the inspector
  eval "$EXEC_CMD"
}