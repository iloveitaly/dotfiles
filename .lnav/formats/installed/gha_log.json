{
  "$schema": "https://lnav.org/schemas/format-v1.schema.json",
  "gha_log": {
    "title": "GitHub Actions Log",
    "description": "Clean view for GitHub Actions CLI logs",
    "regex": {
      "main": {
        "pattern": "^(?<job>[^\t]+)\t(?<step>[^\t]+)\t(?<timestamp>[^\t]+)\t(?<body>.*)$"
      }
    },
    "timestamp-field": "timestamp",
    "body-field": "body",
    "value": {
      "job": {
        "kind": "string",
        "hidden": true
      },
      "step": {
        "kind": "string",
        "hidden": true
      },
      "timestamp": {
        "kind": "string",
        "hidden": true
      },
      "body": {
        "kind": "string"
      }
    },
    "line-format": [
      { "field": "body" }
    ]
  }
}