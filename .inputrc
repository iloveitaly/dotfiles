# readline config (affects python REPL, ruby irb, mysql, psql etc; ignored by zsh)

# no terminal bell
set bell-style none

# case-insensitive tab complete
set completion-ignore-case on

# complete using text after cursor
set skip-completed-text on

# show all on ambiguous
set show-all-if-ambiguous on

# color file types in list
set colored-stats on

# highlight common prefix
set colored-completion-prefix on

# show type symbols (/ * @)
set visible-stats on

# / after symlinked dirs
set mark-symlinked-directories on

# keep cursor on history search
set history-preserve-point on

# up arrow: history search back
"\e[A": history-search-backward

# down arrow: history search forward
"\e[B": history-search-forward

# alt-left: word back (terminal-specific)
"\e[1;3D": backward-word

# alt-right: word forward
"\e[1;3C": forward-word

# UTF-8 input support
set input-meta on
set output-meta on
set convert-meta off