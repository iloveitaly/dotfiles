# Indentation has no syntactic meaning in ssh_config. Tabs, spaces, or lack thereof do not indicate scoping or "what applies after."
# All of the directives placed without a `Host`, etc directive apply globally. Then, we load additional directive files, then
# we have any additional host-specific directives. Placing `Include` last will cause them to be nested under a previous `Host`, etc directive.

TCPKeepAlive yes
KeepAlive yes

ServerAliveInterval 300
ServerAliveCountMax 3
ControlMaster auto
ControlPath /tmp/ssh_mux_%h_%p_%r

Include ~/.ssh/config_extra

# private SSH config
Include ~/.ssh/vscode_config
Include ~/.ssh/op

Host *
  UseKeychain yes
  AddKeysToAgent yes
  IdentityFile ~/.ssh/id_rsa

# fly.io host names change all of the time, this makes it easier to deal with
# `accept-new` only accepts new keys and refuses connections with changed host keys, balancing convenience and security for new hosts while detecting MITM attacks on known hosts.
Host *.internal *.tmate.io *.lan
  StrictHostKeyChecking accept-new
  
# for the opal travel router, without this I can't SSH in
Host 192.168.8.1
  HostKeyAlgorithms +ssh-rsa
  PubkeyAcceptedAlgorithms +ssh-rsa
